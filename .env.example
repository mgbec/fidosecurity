# AWS Configuration
AWS_REGION=us-west-2
AWS_PROFILE=default

# Terraform Variables (alternative to terraform.tfvars)
TF_VAR_aws_region=us-west-2
TF_VAR_environment=dev
TF_VAR_stack_name=smart-advisor
TF_VAR_network_mode=PUBLIC
TF_VAR_image_tag=latest

# Post-deployment values (populated after `terraform output`)
API_ENDPOINT=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=

# For testing with curl (get a JWT from Cognito first)
JWT_TOKEN=
